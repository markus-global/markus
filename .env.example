# LLM Provider API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Database
# Default: SQLite (zero setup, no Docker required) — just leave DATABASE_URL empty or unset
# For PostgreSQL: uncomment and set the URL below
# DATABASE_URL=postgresql://markus:markus@localhost:5432/markus

# Redis (optional — used for pub/sub if available)
REDIS_URL=redis://localhost:6379

# Security — CHANGE THESE in production
ADMIN_PASSWORD=markus123
GATEWAY_SECRET=markus-gateway-default-secret-change-me

# Feishu / Lark (optional)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Search tools (optional)
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=

# Embedding (optional)
EMBEDDING_API_KEY=

# Web UI
WEB_PORT=3000
API_PORT=3001
