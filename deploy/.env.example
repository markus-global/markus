# ─── Markus Docker Configuration ────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LLM Provider API Keys (at least one is required) ──────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GOOGLE_API_KEY=
# DEEPSEEK_API_KEY=
# SILICONFLOW_API_KEY=
# MINIMAX_API_KEY=
# OPENROUTER_API_KEY=
# ZAI_API_KEY=
# XAI_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=
# PERPLEXITY_API_KEY=
# COHERE_API_KEY=
# MOONSHOT_API_KEY=
# VOLCENGINE_API_KEY=
# DASHSCOPE_API_KEY=

# ─── Server Ports ───────────────────────────────────────────────────────────
API_PORT=8056
COMM_PORT=8058

# ─── Feishu / Lark Integration (optional) ──────────────────────────────────
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_WEBHOOK_PORT=9000

# ─── Search API Keys (optional, enables web_search tool) ───────────────────
# Priority: Serper > Tavily > Bing > Google > SerpAPI > Brave > Exa > Bocha > DuckDuckGo (free)
# SERPER_API_KEY=
# TAVILY_API_KEY=
# BING_SEARCH_API_KEY=
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=
# SERPAPI_API_KEY=
# BRAVE_SEARCH_API_KEY=
# EXA_API_KEY=
# BOCHA_API_KEY=

# ─── Security ──────────────────────────────────────────────────────────────
# ADMIN_PASSWORD=markus123
# GATEWAY_SECRET=change-me-in-production

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
