# ─── Markus Docker Configuration ────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── LLM Provider API Keys (at least one is required) ──────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GOOGLE_API_KEY=
# SILICONFLOW_API_KEY=
# MINIMAX_API_KEY=
# OPENROUTER_API_KEY=

# ─── Server Ports ───────────────────────────────────────────────────────────
API_PORT=8056
COMM_PORT=8058

# ─── Feishu / Lark Integration (optional) ──────────────────────────────────
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_WEBHOOK_PORT=9000

# ─── Search API Keys (optional, enables web_search tool) ───────────────────
# SERPER_API_KEY=
# BRAVE_SEARCH_API_KEY=

# ─── Security ──────────────────────────────────────────────────────────────
# ADMIN_PASSWORD=markus123
# GATEWAY_SECRET=change-me-in-production

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
